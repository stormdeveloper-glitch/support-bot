# Support Bot - Environment Variables
# Ushbu faylni .env ga nusxalang va qiymatlarni to'ldiring

# Telegram Bot
SUPPORT_BOT_TOKEN=
SUPPORT_GROUP_ID=
SUPPORT_BOT_USERNAME=
MAIN_BOT_USERNAME=

# Admin sozlamalari
SUPER_ADMIN_ID=
ADMIN_IDS=

# Ma'lumotlar bazasi (PostgreSQL — bo'sh qoldirilsa SQLite ishlatiladi)
DATABASE_URL=

# Server port (default: 5000)
SUPPORT_PORT=5000
